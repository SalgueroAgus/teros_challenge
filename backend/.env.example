OPENAI_API_KEY=                  # platform.openai.com → API Keys
SUPABASE_URL=                    # Supabase Project Settings → API → Project URL
SUPABASE_PUBLISHABLE_KEY=        # Supabase Project Settings → API → Publishable key (replaces anon)
SUPABASE_SECRET_KEY=             # Supabase Project Settings → API → Secret key (replaces service_role) — server-side only

AWS_ACCESS_KEY_ID=          # IAM → Users → Security credentials
AWS_SECRET_ACCESS_KEY=      # IAM → Users → Security credentials
AWS_REGION=                 # e.g. us-east-1